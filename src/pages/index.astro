---
import '../styles/global.css';
---

<!DOCTYPE html>
<html class="light" lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>JayDev Games</title>
  <link rel="icon" type="image/x-icon" href="/jdlogo.png" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
</head>
<body class="text-on-surface">

  <nav class="bg-surface-container-lowest w-full top-0 sticky border-b-border-width-thick border-on-surface z-50">
    <div class="flex justify-between items-center px-margin py-base w-full max-w-full mx-auto">
      <div class="font-headline-md text-headline-md font-black text-on-surface italic uppercase tracking-tighter">
        JAYDEV GAMES
      </div>
      <div class="hidden md:flex gap-gutter items-center">
        <a class="font-label-lg text-label-lg uppercase tracking-widest text-on-surface hover:text-primary transition-colors" href="#projects-section">PROJECTS</a>
        <a class="font-label-lg text-label-lg uppercase tracking-widest text-on-surface hover:text-primary transition-colors" href="#about-section">ABOUT</a>
        <a class="font-label-lg text-label-lg uppercase tracking-widest text-on-surface hover:text-primary transition-colors" href="#community-section">COMMUNITY</a>
        <a class="font-label-lg text-label-lg uppercase tracking-widest text-on-surface hover:text-primary transition-colors" href="#contact-section">CONTACT</a>
      </div>
      <button
        class="bg-secondary-container text-on-secondary-container border-border-width-thin border-on-surface px-6 py-2 font-label-lg text-label-lg neobrutal-shadow neobrutal-button-active transition-all uppercase"
        data-scroll-to="newsletter-section"
      >
        STAY IN THE LOOP
      </button>
    </div>
  </nav>

  <main>

    <section class="pattern-grid min-h-[90vh] flex flex-col justify-center items-center text-center px-margin py-20 relative bg-surface-container-lowest overflow-hidden">
      <div class="absolute inset-0 pointer-events-none z-0">
        <div class="absolute top-1/4 right-20 w-32 h-32 bg-[#ffd7f6] border-4 border-on-surface opacity-80 rotate-[15deg] hidden md:block"></div>
        <div class="absolute -top-10 -left-10 w-48 h-48 bg-[#3b4bff] border-[4px] border-on-surface rounded-full hidden lg:block"></div>
        <div class="absolute bottom-1/4 right-[10%] w-0 h-0 border-l-[60px] border-l-transparent border-r-[60px] border-r-transparent border-b-[#CCFF00] drop-shadow-[4px_4px_0_rgba(0,0,0,1)] rotate-[15deg] hidden md:block" style="border-bottom-width: 100px;"></div>
        <div class="absolute top-1/2 left-10 w-32 h-6 bg-on-surface rotate-[-10deg] hidden xl:block"></div>
        <div class="absolute top-1/3 right-[5%] w-24 h-4 bg-on-surface rotate-[45deg] hidden xl:block"></div>
        <div class="absolute top-[15%] left-[20%] text-6xl font-black text-on-surface opacity-20">+</div>
        <div class="absolute bottom-[20%] left-[15%] text-8xl font-black text-on-surface opacity-10">+</div>
        <div class="absolute top-[60%] right-[15%] text-5xl font-black text-on-surface opacity-20 rotate-12">+</div>
        <div class="absolute top-[10%] right-[30%] w-12 h-12 border-[4px] border-on-surface rotate-45"></div>
        <div class="absolute bottom-[10%] left-[40%] w-20 h-4 bg-secondary-container border-2 border-on-surface"></div>
      </div>
      <div class="relative z-10 max-w-4xl">
        <h1 class="font-display text-display uppercase mb-6 leading-none">
          <span class="inline-block bg-on-surface text-surface-container-lowest px-4 transform -rotate-1">JAYDEV</span><br />
          <span class="inline-block bg-primary text-on-primary px-4 mt-2 transform rotate-1">GAMES</span>
        </h1>
        <p class="font-headline-md text-headline-md mb-margin max-w-2xl mx-auto">
          You've come to the <span class="bg-secondary-container px-2">right place</span>
        </p>
        <div class="flex flex-wrap justify-center gap-gutter">
          <button
            class="bg-secondary-container text-on-secondary-container border-border-width-thick border-on-surface px-margin py-4 font-headline-sm text-headline-sm neobrutal-shadow active:translate-x-1 active:translate-y-1 active:shadow-none transition-all uppercase w-full md:w-auto"
            data-scroll-to="projects-section"
          >PROJECTS</button>
          <button
            class="bg-surface-container-lowest text-on-surface border-border-width-thick border-on-surface px-margin py-4 font-headline-sm text-headline-sm neobrutal-shadow active:translate-x-1 active:translate-y-1 active:shadow-none transition-all uppercase w-full md:w-auto"
            data-scroll-to="about-section"
          >ABOUT</button>
        </div>
      </div>
    </section>

    <section class="bg-on-surface py-20 overflow-hidden border-y-border-width-thick border-on-surface" id="projects-section">
      <div class="px-margin mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <h2 class="font-display text-headline-lg text-surface-container-lowest uppercase italic">PROJECTS</h2>
        <div class="flex gap-4">
          <button
            class="bg-surface-container-lowest p-2 border-border-width-thin border-on-surface neobrutal-shadow active:translate-x-1 active:translate-y-1 active:shadow-none transition-all"
            data-scroll-carousel="left"
          >
            <span class="material-symbols-outlined">arrow_back</span>
          </button>
          <button
            class="bg-surface-container-lowest p-2 border-border-width-thin border-on-surface neobrutal-shadow active:translate-x-1 active:translate-y-1 active:shadow-none transition-all"
            data-scroll-carousel="right"
          >
            <span class="material-symbols-outlined">arrow_forward</span>
          </button>
        </div>
      </div>
      <div class="horizontal-scroll flex gap-margin px-margin overflow-x-auto pb-10" id="game-scroll">
        <a class="block min-w-[300px] md:min-w-[400px] group" href="https://folds.jaydev.games">
          <div class="bg-primary border-border-width-thick border-on-surface p-base neobrutal-shadow-lg transition-transform group-hover:-translate-y-2">
            <div class="h-64 mb-base relative overflow-hidden flex items-center justify-center bg-white border-border-width-thin border-on-surface">
              <img
                alt="FOLDS"
                class="w-32 h-auto object-contain"
                src="https://lh3.googleusercontent.com/aida/ADBb0ugA6e4EZVmzxjx8BGli_zIiF36iHMQrL0WeEoaY-qox9yb3ZaLjh3lFAEJ22BrIbh44hkIPhn2AFK3fqH62PYSnFssjpCZU8f8ht94SM8R5gnj9cUVkFhjBxYrPCA1DgxOiLNoMRS-Ss-E7-DGb0jqvUH__GexNz-OT97YHSGJ9nwjuJWBK9nXBPMh_-vnW_ROs03BbYNvETOenY0XAx4VeGExQTkSoaxbHfSfwMRx3IXVbQc9ovb7xFSq79o2yuW_xio1COlZN-us"
              />
              <div class="absolute bottom-4 left-4 font-label-lg bg-surface-container-lowest px-2 py-1 border-border-width-thin border-on-surface">Coming Late 2026</div>
            </div>
            <div class="bg-surface-container-lowest p-gutter border-border-width-thin border-on-surface">
              <h3 class="font-headline-sm text-headline-sm uppercase mb-2">FOLDS</h3>
              <p class="font-body-md text-body-md mb-4">A symmetrical puzzle game that'll leave you in Folds</p>
              <div class="flex justify-between items-center">
                <span class="font-label-sm text-label-sm uppercase bg-tertiary-fixed px-2">PUZZLE</span>
                <span class="material-symbols-outlined">bolt</span>
              </div>
            </div>
          </div>
        </a>
        <div class="min-w-[300px] md:min-w-[400px] bg-secondary-container border-border-width-thick border-on-surface p-base neobrutal-shadow-lg">
          <div class="h-64 mb-base relative overflow-hidden flex items-center justify-center bg-surface-container-highest pattern-diagonal">
            <div class="w-24 h-24 bg-surface-container-lowest border-border-width-thick border-on-surface flex items-center justify-center">
              <span class="material-symbols-outlined text-[64px]">construction</span>
            </div>
          </div>
          <div class="bg-surface-container-lowest p-gutter border-border-width-thin border-on-surface">
            <h3 class="font-headline-sm text-headline-sm uppercase mb-2">PROJECT II</h3>
            <p class="font-body-md text-body-md mb-4">We're building something exciting. Stay tuned for updates.</p>
            <div class="flex justify-between items-center">
              <span class="font-label-sm text-label-sm uppercase bg-primary-fixed px-2">PROJECT UNDER CONSTRUCTION</span>
              <span class="material-symbols-outlined">construction</span>
            </div>
          </div>
        </div>
        <div class="min-w-[300px] md:min-w-[400px] bg-tertiary-fixed border-border-width-thick border-on-surface p-base neobrutal-shadow-lg">
          <div class="h-64 mb-base relative overflow-hidden flex items-center justify-center bg-on-surface">
            <div class="w-24 h-24 bg-tertiary-fixed border-border-width-thick border-on-surface flex items-center justify-center">
              <span class="material-symbols-outlined text-[64px]">question_mark</span>
            </div>
          </div>
          <div class="bg-surface-container-lowest p-gutter border-border-width-thin border-on-surface">
            <h3 class="font-headline-sm text-headline-sm uppercase mb-2">UNKNOWN PROJECT</h3>
            <p class="font-body-md text-body-md mb-4">Top secret project in development. Shhh!</p>
            <div class="flex justify-between items-center">
              <span class="font-label-sm text-label-sm uppercase bg-secondary-fixed px-2">???</span>
              <span class="material-symbols-outlined">question_mark</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-margin bg-surface-container-lowest relative overflow-hidden" id="about-section">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-margin items-center">
        <div class="order-2 md:order-1">
          <div class="inline-block bg-secondary-container border-border-width-thin border-on-surface px-4 py-1 mb-base font-label-lg uppercase">ABOUT THE DEV</div>
          <h2 class="font-display text-headline-lg uppercase leading-tight mb-margin">
            JAYDEV<br />
            <span class="text-primary italic">the guy behind it all</span>
          </h2>
          <div class="mb-margin">
            <h3 class="font-display text-headline-sm uppercase mb-2">THE STORY SO FAR</h3>
            <p class="font-body-md text-body-md text-on-surface opacity-90 mb-4">
              JayDev started out as a small indie game developer designing all sorts of mini games, as a hobby. Then, with passion, strife and a little bit of delusion, the JayDev Games empire began.
            </p>
            <p class="font-body-md text-body-md text-on-surface opacity-90">
              JayDev resides in Australia as a student developer &amp; graphic designer, with experience in HTML, CSS and JS coding and UI/UX design.
            </p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-gutter">
            <div class="flex items-start gap-4">
              <div class="bg-primary text-on-primary w-10 h-10 flex-shrink-0 flex items-center justify-center border-border-width-thin border-on-surface neobrutal-shadow">
                <span class="material-symbols-outlined">favorite</span>
              </div>
              <div>
                <h4 class="font-label-lg uppercase">100% Indie</h4>
                <p class="text-sm opacity-80">I answer to no one but the players. No suits, no publishers, no compromises.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="bg-secondary-container text-on-secondary-container w-10 h-10 flex-shrink-0 flex items-center justify-center border-border-width-thin border-on-surface neobrutal-shadow">
                <span class="material-symbols-outlined">bolt</span>
              </div>
              <div>
                <h4 class="font-label-lg uppercase">Experimental</h4>
                <p class="text-sm opacity-80">Always playing around with new concepts with familiar feels.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="bg-tertiary-fixed-dim w-10 h-10 flex-shrink-0 flex items-center justify-center border-border-width-thin border-on-surface neobrutal-shadow">
                <span class="material-symbols-outlined">diversity_3</span>
              </div>
              <div>
                <h4 class="font-label-lg uppercase">Community Core</h4>
                <p class="text-sm opacity-80">The Discord builds our games. Feedback isn't a gift, it's my engine.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="bg-primary-fixed-dim w-10 h-10 flex-shrink-0 flex items-center justify-center border-border-width-thin border-on-surface neobrutal-shadow">
                <span class="material-symbols-outlined">share</span>
              </div>
              <div>
                <h4 class="font-label-lg uppercase">Social Presence</h4>
                <p class="text-sm opacity-80">I'm on your favourite platforms, so you'll always be in the loop.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="order-1 md:order-2 grid grid-cols-2 gap-gutter">
          <div class="aspect-square bg-primary border-border-width-thick border-on-surface neobrutal-shadow-lg flex items-center justify-center">
            <div class="font-display text-7xl text-on-primary">!</div>
          </div>
          <div class="aspect-square bg-secondary-container border-border-width-thick border-on-surface neobrutal-shadow-lg flex items-center justify-center">
            <span class="material-symbols-outlined text-6xl">rocket_launch</span>
          </div>
          <div class="aspect-square bg-on-surface border-border-width-thick border-on-surface neobrutal-shadow-lg flex items-center justify-center">
            <div class="w-full h-full border-border-width-thick border-primary-container pattern-diagonal opacity-30"></div>
          </div>
          <div class="aspect-square bg-surface-container-lowest border-border-width-thick border-on-surface neobrutal-shadow-lg flex items-center justify-center p-base">
            <div class="flex gap-2">
              <div class="w-4 h-16 bg-primary"></div>
              <div class="w-4 h-16 bg-primary"></div>
              <div class="w-4 h-16 bg-primary"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-margin bg-surface-container-lowest border-t-border-width-thick border-on-surface pattern-grid relative overflow-hidden" id="community-section">
      <div class="mx-auto w-full">
        <div class="mb-12 px-margin">
          <div class="inline-block bg-secondary-container border-border-width-thin border-on-surface px-4 py-1 mb-base font-label-lg uppercase">OUR LEGENDS</div>
          <h2 class="font-display text-headline-lg uppercase italic text-primary leading-tight">
            COMMUNITY<br />
            <span class="text-on-surface not-italic">WALL OF FAME</span>
          </h2>
        </div>
        <div class="flex flex-col items-center gap-12 w-full overflow-hidden">
          <div class="ticker-wrap w-full">
            <div class="ticker-move">
              <div class="flex gap-6 px-4">
                <div class="bg-primary border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow rotate-1"><span class="font-label-lg text-on-primary uppercase text-lg">Carrot</span></div>
                <div class="bg-secondary-container border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow -rotate-2"><span class="font-label-lg text-on-secondary-container uppercase text-lg">Sahas</span></div>
                <div class="bg-primary border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow rotate-2"><span class="font-label-lg text-on-primary uppercase text-lg">Newaccount</span></div>
                <div class="bg-secondary-container border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow -rotate-1"><span class="font-label-lg text-on-secondary-container uppercase text-lg">Vegeta897</span></div>
                <div class="bg-primary border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow rotate-3"><span class="font-label-lg text-on-primary uppercase text-lg">Big V</span></div>
                <div class="bg-secondary-container border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow -rotate-3"><span class="font-label-lg text-on-secondary-container uppercase text-lg">Dhanvitha</span></div>
                <div class="bg-primary border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow -rotate-1"><span class="font-label-lg text-on-primary uppercase text-lg">JadenJJL</span></div>
                <div class="bg-secondary-container border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow rotate-2"><span class="font-label-lg text-on-secondary-container uppercase text-lg">ahaha_24</span></div>
                <div class="bg-primary border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow rotate-1"><span class="font-label-lg text-on-primary uppercase text-lg">yaolychee</span></div>
                <div class="bg-secondary-container border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow -rotate-2"><span class="font-label-lg text-on-secondary-container uppercase text-lg">@SynthWave</span></div>
              </div>
              <div class="flex gap-6 px-4">
                <div class="bg-primary border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow rotate-1"><span class="font-label-lg text-on-primary uppercase text-lg">@GameMaster96</span></div>
                <div class="bg-secondary-container border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow -rotate-2"><span class="font-label-lg text-on-secondary-container uppercase text-lg">@PizzaCat</span></div>
                <div class="bg-primary border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow rotate-2"><span class="font-label-lg text-on-primary uppercase text-lg">@Zoomer</span></div>
                <div class="bg-secondary-container border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow -rotate-1"><span class="font-label-lg text-on-secondary-container uppercase text-lg">@DevDan</span></div>
                <div class="bg-primary border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow rotate-3"><span class="font-label-lg text-on-primary uppercase text-lg">@IndieIris</span></div>
                <div class="bg-secondary-container border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow -rotate-3"><span class="font-label-lg text-on-secondary-container uppercase text-lg">@PixelPal</span></div>
                <div class="bg-primary border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow -rotate-1"><span class="font-label-lg text-on-primary uppercase text-lg">@GlitchGal</span></div>
                <div class="bg-secondary-container border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow rotate-2"><span class="font-label-lg text-on-secondary-container uppercase text-lg">@CodeKing</span></div>
                <div class="bg-primary border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow rotate-1"><span class="font-label-lg text-on-primary uppercase text-lg">@RetroRacer</span></div>
                <div class="bg-secondary-container border-border-width-thin border-on-surface px-6 py-3 neobrutal-shadow -rotate-2"><span class="font-label-lg text-on-secondary-container uppercase text-lg">@SynthWave</span></div>
              </div>
            </div>
          </div>
          <button class="bg-surface-container-lowest border-border-width-thick border-dashed border-on-surface px-16 py-6 neobrutal-shadow hover:scale-105 active:translate-x-1 active:translate-y-1 active:shadow-none transition-all">
            <span class="font-headline-sm text-on-surface italic uppercase">YOUR NAME HERE?</span>
          </button>
        </div>
      </div>
    </section>

    <section class="bg-primary-container py-margin px-margin border-y-border-width-thick border-on-surface" id="newsletter-section">
      <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-margin">
        <div class="flex-1">
          <h2 class="font-headline-lg text-headline-lg text-on-primary-container uppercase leading-none mb-2">STAY IN THE LOOP</h2>
          <p class="font-body-lg text-body-lg text-on-primary-container opacity-90">No spam. Only game updates and secret beta codes.</p>
        </div>
        <div class="w-full md:w-auto flex flex-col sm:flex-row gap-0">
          <input
            class="bg-surface-container-lowest border-border-width-thick border-on-surface px-margin py-4 font-label-lg text-label-lg w-full sm:w-80 focus:ring-0 focus:outline-none focus:bg-secondary-fixed transition-colors"
            placeholder="YOUR@EMAIL.COM"
            type="email"
          />
          <button class="bg-on-surface text-surface-container-lowest px-margin py-4 font-headline-sm text-headline-sm border-y-border-width-thick border-r-border-width-thick border-l-border-width-thick sm:border-l-0 border-on-surface neobrutal-shadow active:translate-x-1 active:translate-y-1 active:shadow-none transition-all uppercase whitespace-nowrap">JOIN</button>
        </div>
      </div>
    </section>

  </main>

  <footer class="bg-on-surface border-t-border-width-thick border-on-surface" id="contact-section">
    <div class="flex flex-col md:flex-row justify-between items-center px-margin py-margin w-full gap-gutter">
      <div class="font-headline-sm text-headline-sm font-black text-secondary-container uppercase tracking-tighter">JAYDEV GAMES</div>
      <div class="flex flex-wrap gap-gutter justify-center">
        <a class="font-body-md text-body-md text-surface-container-low hover:text-secondary-fixed transition-colors" href="https://discord.gg/eaE7CrWvsW">Discord</a>
        <a class="font-body-md text-body-md text-surface-container-low hover:text-secondary-fixed transition-colors" href="https://youtube.com/@JayDevGames1">YouTube</a>
        <a class="font-body-md text-body-md text-surface-container-low hover:text-secondary-fixed transition-colors" href="https://www.tiktok.com/@jaydevgames">TikTok</a>
        <a class="font-body-md text-body-md text-surface-container-low hover:text-secondary-fixed transition-colors" href="https://www.instagram.com/jaydev_games?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==">Instagram</a>
      </div>
      <div class="font-body-md text-body-md text-surface-container-low uppercase opacity-60">©2026 JAYDEV GAMES</div>
    </div>
  </footer>

  <script>
    import '../scripts/index.ts';
  </script>

</body>
</html>